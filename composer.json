{
    "name": "saddlephp/saddlephp",
    "description": "The open-source admin panel framework for Laravel, built for Inertia and Vue. Define a resource, get a polished panel.",
    "keywords": ["laravel", "admin", "admin-panel", "crud", "inertia", "vue", "panel", "saddlephp"],
    "homepage": "https://saddlephp.com",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "SaddlePHP", "homepage": "https://saddlephp.com" }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "inertiajs/inertia-laravel": "^3.1"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "SaddlePHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SaddlePHP\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SaddlePHP\\SaddleServiceProvider"
            ],
            "aliases": {
                "Saddle": "SaddlePHP\\Facades\\Saddle"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
